# Build outputs
/build/
/build-*/
/out/
/.happypath/

# Recompiler output (derivative of copyrighted game code — regenerate locally)
/generated/

# Release packaging artifacts
/release-stage/
*.zip
# Downloaded toolchain artifacts cached by package_release.ps1 (fetched on demand)
/tools/_toolchain_cache/

# Per-game launcher art. launcher_art/img/disc.png (the game's boxart shown in
# the launcher) IS committed so the shipped launcher shows Tsumu's cover, not the
# framework's default disc (matches MegaManX6Recomp). Any other local art stays out.
/launcher_art/*
!/launcher_art/img/
/launcher_art/img/*
!/launcher_art/img/disc.png

# Local scratch / screenshot dirs
/scratch_old/
/shots/

# Local PlayStation assets (disc image, extracted boot EXE, memory cards)
/tsumu/
/isos/
/saves/
/_extract/

# Disc / image / memcard formats
*.bin
*.cue
*.iso
*.img
*.sub
*.ccd
*.mcd
*.mcr
*.chd

# Ghidra: keep instructions.txt + scripts/ + annotations/, drop the live DB + dumps
/ghidra/projects/
/ghidra/*_no_header.bin
*.gpr
*.rep/
*.lock
*.lock~

# Local editor / cache files
.vs/
.vscode/
*.user
*.log

# Runtime artifacts from psx-runtime launches
psx_crash.txt
psx_last_run_report.json
psx_screenshot.bmp
psx_freeze_heartbeat.json
starvation_dump.jsonl

# Diagnostic dumps from debug-server probes (root-level only; keep annotations/ tracked)
/*.json
/*.bmp
/*.png

# Python caches
__pycache__/

# Root-level scratch / probe artifacts (keep annotations/, seeds/, translations/)
/_*.txt
/_*.hex
/_*.json
/_*.bmp
/_*.png
/_*.c
/_*.dll
/_*.exe
